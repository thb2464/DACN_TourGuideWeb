{
  "kind": "collectionType",
  "collectionName": "tours",
  "info": {
    "singularName": "tour",
    "pluralName": "tours",
    "displayName": "Tour"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "Tour_Name": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "Tour_Name",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Short_Description": {
      "type": "text",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Description": {
      "type": "blocks",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Featured_Image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"],
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Price": {
      "type": "biginteger",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Original_Price": {
      "type": "biginteger",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Child_Price": {
      "type": "biginteger",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Duration_Days": {
      "type": "integer",
      "pluginOptions": {
        "i18n": { "localized": false }
      }
    },
    "Duration_Nights": {
      "type": "integer",
      "pluginOptions": {
        "i18n": { "localized": false }
      }
    },
    "Region": {
      "type": "enumeration",
      "enum": [
        "MienBac",
        "MienTrung",
        "MienNam",
        "TayNguyen",
        "NhieuVung"
      ],
      "pluginOptions": {
        "i18n": { "localized": false }
      }
    },
    "Location": {
      "type": "string",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Departure_Location": {
      "type": "string",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Itinerary": {
      "type": "blocks",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Highlights": {
      "type": "component",
      "repeatable": true,
      "component": "card.tour-highlight",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Max_Participants": {
      "type": "integer",
      "pluginOptions": {
        "i18n": { "localized": false }
      }
    },
    "Rating": {
      "type": "decimal",
      "pluginOptions": {
        "i18n": { "localized": false }
      }
    },
    "Review_Count": {
      "type": "integer",
      "pluginOptions": {
        "i18n": { "localized": false }
      }
    },
    "Transport_Type": {
      "type": "enumeration",
      "enum": [
        "XeKhach",
        "MayBay",
        "Tau",
        "XeMay",
        "KetHop"
      ],
      "pluginOptions": {
        "i18n": { "localized": false }
      }
    },
    "Is_Featured": {
      "type": "boolean",
      "default": false,
      "pluginOptions": {
        "i18n": { "localized": false }
      }
    },
    "tour_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tour-category.tour-category",
      "inversedBy": "tours"
    }
  }
}
